Exercise 3: Create a NodePort Service and access it from your host
--------------------------------------------------------------------

cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Service
metadata:
  name: web-nodeport
spec:
  type: NodePort
  selector:
    app: web
  ports:
  - port: 80
    targetPort: 80
    nodePort: 30080   # Optional: choose a specific port (30000-32767)
EOF

# Check the assigned node port
kubectl get svc web-nodeport

# Access it from your laptop (works with Kind)
curl http://localhost:30080



Exercise 4: Inspect how Services track Pods using Endpoints
-------------------------------------------------------------

# Scale the deployment up and down and watch Endpoints change
kubectl scale deployment web --replicas=5
kubectl get endpoints web -w

# View detailed endpoint information
kubectl get endpoints web -o yaml

# Delete one pod and observe how quickly the endpoint is updated
kubectl delete pod -l app=web --grace-period=0 --force



Exercise 5: Use label selectors to control which Pods a 
            Service targets
--------------------------------------------------------------

# Add an extra label to one of the pods
POD=$(kubectl get pods -l app=web --no-headers | head -1 | awk '{print $1}')
kubectl label pod $POD version=v2 --overwrite

# Create a new Service that only targets pods with version=v2
cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: Service
metadata:
  name: web-v2
spec:
  selector:
    app: web
    version: v2
  ports:
  - port: 80
    targetPort: 80
EOF

kubectl get endpoints web-v2



Exercise 6: Clean up
----------------------------------------------------

kubectl delete deployment web
kubectl delete svc web web-nodeport web-v2

