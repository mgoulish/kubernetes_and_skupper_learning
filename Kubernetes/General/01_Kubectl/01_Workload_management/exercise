# Exercise 2: Declarative Pod Creation
# -------------------------------------

# Save this as 'deployment.yaml'
{
apiVersion: apps/v1
kind: Deployment
metadata:
  name: web
  labels:
    app: web
spec:
  replicas: 2
  selector:
    matchLabels:
      app: web
  template:
    metadata:
      labels:
        app: web
    spec:
      containers:
      - name: nginx
        image: nginx:alpine
        ports:
        - containerPort: 80
}

# Apply the YAML description
kubectl apply -f deployment.yaml

# Show the deployment
kubectl get deployments
kubectl get pods --show-labels       # See what the labels are
                                     # This is how you can tell that two pods are 
                                     # replicas of the same workload.
kubectl get pods -l app=web          # Show pods with a label selector

# Delete the deployment
kubectl delete deployment web





